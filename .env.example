# Copy this file to .env for local development.
# .env is git-ignored and must never be committed.

# Show /docs and /redoc in the running app (disable in production if desired)
DOCS_ENABLED=true

# Comma-separated list of allowed frontend origins.
# REQUIRED in production — change from * to your actual domain(s).
# Example: CORS_ORIGINS=https://app.yourcompany.com,https://admin.yourcompany.com
CORS_ORIGINS=*
